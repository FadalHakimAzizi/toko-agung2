# ============================================================
# Konfigurasi environment - Toko Alat Tulis Agung
# Salin file ini menjadi ".env" lalu isi nilainya.
# ============================================================

# --- Database PostgreSQL (Supabase) ---
# Ambil dari Supabase Dashboard > Project Settings > Database > Connection string (URI).
# Gunakan "Session pooler" (port 5432). Ganti [YOUR-PASSWORD] dengan password database Anda.
DATABASE_URL=postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Paksa SSL untuk koneksi database (Supabase otomatis terdeteksi, biarkan false untuk lokal)
DATABASE_SSL=false

# --- Supabase Storage (untuk upload bukti pembayaran & QRIS saat deploy) ---
# Wajib diisi saat deploy ke serverless (Vercel) karena filesystem read-only.
# Ambil di Supabase Dashboard > Project Settings > API.
# Jika dikosongkan, file disimpan ke folder lokal public/uploads (khusus development).
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# --- Chatbot RAG: LLM untuk Generation ---
# Jika diisi, chatbot memakai LLM untuk menyusun jawaban dari konteks yang ditemukan.
# Jika kosong, chatbot tetap jalan memakai jawaban template (fallback aman).
# AI_BASE_URL: endpoint apa pun yang kompatibel dengan OpenAI Chat Completions API.
# Contoh memakai Groq (gratis, cepat):
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# --- Chatbot RAG: Embedding untuk Retrieval (pgvector) ---
# Jika diisi, retrieval knowledge base memakai semantic search (paham makna).
# Jika kosong, retrieval otomatis fallback ke keyword search (tetap berfungsi).
# Dimensi vektor = 768 (harus sama dengan kolom vector(768) di database).
# Pilihan provider (pilih salah satu):
#   Jina AI (gratis, tanpa kartu):  BASE_URL=https://api.jina.ai/v1  MODEL=jina-embeddings-v3
#   Google Gemini:                  BASE_URL=https://generativelanguage.googleapis.com/v1beta  MODEL=gemini-embedding-001
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.jina.ai/v1
EMBEDDING_MODEL=jina-embeddings-v3
